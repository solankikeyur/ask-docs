APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Document storage disk — set to 's3' in production / Laravel Cloud.
# Local dev:   DOCUMENT_STORAGE_DISK=public  (storage/app/public)
# Production:  DOCUMENT_STORAGE_DISK=s3      (requires AWS_* vars above)
DOCUMENT_STORAGE_DISK=public

COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v4.0-fast

VITE_APP_NAME="${APP_NAME}"

# AI & RAG Configuration
AI_COMPLETION_MODEL=gpt-4o-mini-2024-07-18
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EXPANSION_MODEL=gpt-4o-mini-2024-07-18
AI_EMBEDDING_DIMENSIONS=1536

# Retrieval Settings
AI_SIMILARITY_THRESHOLD=0.35
AI_RERANK_CANDIDATE_LIMIT=25
AI_CONTEXT_CHUNK_LIMIT=6
AI_SEARCH_LIMIT=100
AI_EXPANSION_COUNT=3

# Rerank Settings
AI_RERANK_ENABLED=true
AI_RERANK_MAX_CHARS=1000
AI_RERANK_CACHE_EXPIRY=600
AI_RERANK_TIMEOUT=8
AI_RERANK_RETRIES=2
AI_RERANK_SCORE_THRESHOLD=0.3

# Timeouts & Limits
AI_COMPLETION_TIMEOUT=20
AI_EXPANSION_TIMEOUT=10
AI_PAGINATION_LIMIT=100
AI_MAX_MESSAGE_LENGTH=10000
